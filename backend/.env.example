DATABASE_URL="file:./dev.db"

# Required. Must be a strong random string of at least 32 characters — the server
# refuses to start otherwise. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=""

PORT=3001

# Comma-separated list of allowed frontend origins for CORS (prod).
# ALLOWED_ORIGINS="https://your-frontend.example.com"

# Used to build links in transactional emails.
# FRONTEND_URL="http://localhost:3000"

# Resend (transactional email). Optional locally; required for email features.
# RESEND_API_KEY=""

# Web Push (VAPID). Optional; required for push notifications.
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
