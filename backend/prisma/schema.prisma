generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  username             String?   @unique
  password             String
  createdAt            DateTime  @default(now())
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  timezone             String    @default("UTC")
  totalTasksCompleted  Int       @default(0)
  maxStreak            Int       @default(0)
  emailReminders       Boolean   @default(true)
  bio                  String?
  avatar               String?

  tasks              Task[]
  pushupSessions     PushupSession[]
  pushupDebts        PushupDebt[]
  sentRequests       Friendship[]    @relation("SentRequests")
  receivedRequests   Friendship[]    @relation("ReceivedRequests")
  challengesGiven    Challenge[]     @relation("ChallengesGiven")
  challengesReceived Challenge[]     @relation("ChallengesReceived")
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId Int
  receiverId  Int
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Challenge {
  id           Int       @id @default(autoincrement())
  challengerId Int
  challengedId Int
  type         String
  durationDays Int
  status       String    @default("pending")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())

  challenger User @relation("ChallengesGiven", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged User @relation("ChallengesReceived", fields: [challengedId], references: [id], onDelete: Cascade)
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  completed   Boolean   @default(false)
  recurrence  String    @default("none")
  createdAt   DateTime  @default(now())
  dueDate     DateTime
  completedAt DateTime?
  deletedAt   DateTime?
  userId      Int

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushupDebt PushupDebt?
}

model PushupDebt {
  id              Int      @id @default(autoincrement())
  taskId          Int?     @unique
  userId          Int
  pushupsOwed     Float
  daysOverdue     Int
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushupSession {
  id               Int      @id @default(autoincrement())
  pushupsCompleted Int
  date             DateTime @default(now())
  userId           Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
