generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int       @id @default(autoincrement())
  email                String    @unique
  username             String?   @unique
  password             String
  createdAt            DateTime  @default(now())
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  timezone             String    @default("UTC")
  totalQuestsCompleted Int       @default(0) @map("totalTasksCompleted")
  maxStreak            Int       @default(0)
  emailReminders         Boolean   @default(true)
  bio                    String?
  avatar                 String?
  coins                  Int       @default(0)
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?
  loginAttempts          Int       @default(0)
  lockedUntil            DateTime?

  xp                    Int       @default(0)
  level                 Int       @default(1)

  streakShieldActive    Boolean   @default(false)
  debtFreezeUntil       DateTime?
  payoffMultiplierActive Boolean  @default(false) @map("pushupMultiplierActive")
  profileFlair          String?

  quests             Quest[]
  payoffSessions     PayoffSession[]
  debts              Debt[]
  sentRequests       Friendship[]       @relation("SentRequests")
  receivedRequests   Friendship[]       @relation("ReceivedRequests")
  challengesGiven    Challenge[]        @relation("ChallengesGiven")
  challengesReceived Challenge[]        @relation("ChallengesReceived")
  pushSubscriptions  PushSubscription[]
  inventory          UserItem[]
}

model Friendship {
  id          Int      @id @default(autoincrement())
  requesterId Int
  receiverId  Int
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("SentRequests", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Challenge {
  id           Int       @id @default(autoincrement())
  challengerId Int
  challengedId Int
  type         String
  durationDays Int
  status       String    @default("pending")
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime  @default(now())

  challenger User @relation("ChallengesGiven", fields: [challengerId], references: [id], onDelete: Cascade)
  challenged User @relation("ChallengesReceived", fields: [challengedId], references: [id], onDelete: Cascade)
}

// Mapped to the legacy "Task" table — physical DB names unchanged by the
// PushupDebt → SideQuest rebrand so no data migration is required.
model Quest {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  completed   Boolean   @default(false)
  recurrence  String    @default("none")
  createdAt   DateTime  @default(now())
  dueDate     DateTime
  completedAt DateTime?
  deletedAt   DateTime?
  userId      Int

  category    String    @default("other")
  difficulty  String    @default("medium")
  xpReward    Int       @default(50)
  debtType    String    @default("pushups")
  debtAmount  Int       @default(5)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt Debt?

  @@index([userId, deletedAt])
  @@index([dueDate])
  @@index([completedAt])
  @@map("Task")
}

// Mapped to the legacy "PushupDebt" table.
model Debt {
  id              Int      @id @default(autoincrement())
  questId         Int?     @unique @map("taskId")
  userId          Int
  amountOwed      Float    @map("pushupsOwed")
  daysOverdue     Int
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quest Quest? @relation(fields: [questId], references: [id], onDelete: SetNull)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, resolved])
  @@map("PushupDebt")
}

// Mapped to the legacy "PushupSession" table.
model PayoffSession {
  id       Int      @id @default(autoincrement())
  amount   Int      @map("pushupsCompleted")
  activity String   @default("fitness") // fitness | focus | wellness | chores | custom
  date     DateTime @default(now())
  userId   Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("PushupSession")
}

model UserItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  itemId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
